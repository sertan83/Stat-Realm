# Generate with: npx auth secret
AUTH_SECRET=

# Public origin only, with no trailing slash (for example, your local or deployed origin)
AUTH_URL=

# Obtain from https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Optional: persistent database storage on Vercel (link a Vercel KV / Upstash Redis store)
# Vercel KV injects KV_REST_API_URL and KV_REST_API_TOKEN automatically.
# Upstash direct integrations may use UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: disable local JSON database writes during development
# STATREALM_DISABLE_FILE_DB=1
